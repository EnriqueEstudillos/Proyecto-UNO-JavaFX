        <mxCell id="2o95ah_u2O1L0ixTK-m4-37" value="SELECT H.*&amp;nbsp;&lt;div&gt;FROM HISTORIAL H&lt;/div&gt;&lt;div&gt;INNER JOIN Jugadores_x_Partida jp ON h.ID_Partida=jp.ID_Partida&lt;/div&gt;&lt;div&gt;WHERE jp.ID_Jugador = 1&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">

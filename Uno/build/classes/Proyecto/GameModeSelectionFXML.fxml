<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="900.0" prefWidth="1600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Proyecto.GameModeSelectionFXMLController">
    <children>
        <!-- 1V1 Button -->
        <ImageView fx:id="Button1v3" fitHeight="100.0" fitWidth="200.0" layoutX="700.0" layoutY="450.0" pickOnBounds="true" preserveRatio="true">
           <image>
              <Image url="@../Imagenes/Botones/1v3.png" />
           </image>
        </ImageView>
        <!-- 1V3 Button -->
        <ImageView fx:id="Button1v1" fitHeight="100.0" fitWidth="200.0" layoutX="700.0" layoutY="300.0" pickOnBounds="true" preserveRatio="true">
           <image>
              <Image url="@../Imagenes/Botones/1v1.png" />
           </image>
        </ImageView>
        <!-- Exit Button -->
        <ImageView fx:id="BackButton" fitHeight="100.0" fitWidth="200.0" layoutX="700.0" layoutY="750.0" pickOnBounds="true" preserveRatio="true">
           <image>
              <Image url="@../Imagenes/Botones/Back.png" />
           </image>
        </ImageView>
   </children>
</AnchorPane>
